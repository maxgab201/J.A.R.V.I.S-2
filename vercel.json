{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.js": {
      "memory": 512,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/extension/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/extension/jarvis-tab-controller.zip",
      "headers": [
        { "key": "Content-Type", "value": "application/zip" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"jarvis-tab-controller.zip\"" }
      ]
    }
  ]
}
